# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Local:  postgresql://USER:PASSWORD@localhost:5432/vedaai
# Neon:   postgresql://USER:PASSWORD@HOST/vedaai?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/vedaai"


# ── Redis (for BullMQ) ────────────────────────────────────────────────────────
# Local:             redis://localhost:6379
# Upstash (free):    rediss://default:TOKEN@HOST:PORT
REDIS_URL="redis://localhost:6379"

# ── AI APIs ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"
MISTRAL_API_KEY="your-mistral-api-key"

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"

# ── File Uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10
